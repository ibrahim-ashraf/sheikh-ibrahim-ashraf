{
  "name": "alsheikhibrahimashraf",
  "main": "expo-router/entry",
  "version": "1.3.3",
  "scripts": {
    "start": "expo start",
    "start:expo": "expo start -c",
    "start:dev": "expo start --dev-client -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "test": "jest --watchAll",
    "clean": "expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "build:dev": "eas build --profile development --platform android",
    "build:preview": "eas build --profile preview --platform android",
    "build:prod": "eas build --profile production --platform android",
    "submit": "eas submit --profile production --platform android --latest"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-google-signin/google-signin": "^13.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "expo": "~53.0.27",
    "expo-asset": "~11.1.7",
    "expo-build-properties": "~0.14.8",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.2",
    "expo-linking": "~7.1.7",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-google-mobile-ads": "^14.7.0",
    "react-native-purchases": "^9.6.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-webview": "13.13.5",
    "react-native-youtube-iframe": "^2.3.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3",
    "@babel/core": "^7.20.0"
  },
  "private": true,
  "expo": {
    "newArchEnabled": true
  }
}